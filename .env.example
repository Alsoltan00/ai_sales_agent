# .env
# ملف الإعدادات السرية — لا ترفع هذا الملف على GitHub!

# ============================
# Main Database (Aiven PostgreSQL)
# ============================
DATABASE_URL=postgresql://avnadmin:your_password_here@pg-xyz.aivencloud.com:27013/defaultdb?sslmode=require

# ============================
# Server Settings
# ============================
HOST=0.0.0.0
PORT=8000
DEBUG=false
SESSION_SECRET=change-this-to-a-random-secret-string-at-least-32-chars

# ============================
# Sync Intervals (بالدقائق)
# ============================
SUPABASE_SYNC_INTERVAL=5
AIVEN_SYNC_INTERVAL=5
GSHEETS_SYNC_INTERVAL=30
